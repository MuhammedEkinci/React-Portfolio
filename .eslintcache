r\nimport \"../styles/Portfolio.css\";\r\n\r\nfunction Portfolio() {\r\n\r\n    return (\r\n        <Container fluid >\r\n            <Row>\r\n                <Col md={12} className=\"project-heading\">\r\n                    <h1 style={{textAlign: \"center\"}}>Projects</h1>\r\n                </Col>\r\n                <CardDeck>\r\n                    {data.map((project, i) => {\r\n                        return (\r\n                            <Col md={6}>\r\n                                <div key={i} className=\"cards\">\r\n                                    <Card>\r\n                                        <Card.Img className='cardImage' src={project.image} alt={project.alt}></Card.Img>\r\n                                        <div className=\"card-body\">\r\n                                            <Card.Body>\r\n                                                <Card.Title className=\"cardHeader\">{project.name}</Card.Title>\r\n                                                <Card.Text className=\"project-text\">{project.text}</Card.Text>\r\n                                                <Button className=\"app-btn\" variant=\"outline-primary\"  onClick={(e) => {e.preventDefault(); window.location.href=`${project.appUrl}`}}>Deploy The App</Button>\r\n                                                <Button className=\"github-btn\" variant=\"outline-primary\" onClick={(e) => {e.preventDefault(); window.location.href=`${project.githubUrl}`}}>Github Repository</Button>\r\n                                            </Card.Body>\r\n                                        </div>\r\n                                    </Card>\r\n                                </div>\r\n                            </Col>\r\n                        );\r\n                    })}\r\n                </CardDeck>\r\n            </Row>\r\n        </Container>\r\n    );\r\n};\r\n\r\nexport default Portfolio;","C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\src\\pages\\HomePage.js",[],"C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\src\\pages\\AboutMe.js",["54"],"\r\nimport React from 'react';\r\nimport '../styles/AboutMe.css';\r\nimport Picture from \"../images/MyProfile.JPG\";\r\nimport { Container, Row, Col, Image } from \"react-bootstrap\";\r\n\r\n\r\nfunction AboutMe() {\r\n\r\n    return (\r\n        <div>\r\n            <Container fluid>\r\n                <Row>\r\n                    <Col sm={12} lg={4}> \r\n                        <div id=\"profile\">\r\n                            <Image id=\"my-pic\" className=\"avatar avatar-circle\" src={Picture}/>\r\n                            <div className=\"portrait-title\">\r\n                                <h2>Muhammed Siraceddin Ekinci</h2>\r\n                                <h3>CS Major Student</h3>\r\n                                <h3>\r\n                                    <a href=\"https://www.wpunj.edu/\" target=\"_blank\" rel=\"noopener\">\r\n                                        <span>William Paterson University</span>\r\n                                    </a>\r\n                                </h3>\r\n                            </div>\r\n                            <ul className=\"network-icon d-flex auto-mx justify-content-center\" aria-hidden=\"true\">\r\n                                <li className=\"list-inline-item icon\">\r\n                                    <a href=\"mailto:siraceddinekinci@gmail.com\" rel=\"noreferrer\" target=\"_blank\">\r\n                                        <i class=\"fas fa-envelope\"></i>\r\n                                    </a>\r\n                                </li>\r\n                                <li className=\"list-inline-item icon\">\r\n                                    <a href=\"https://github.com/MuhammedEkinci\" rel=\"noreferrer\" target=\"_blank\">\r\n                                        <i class=\"fab fa-github\"></i>\r\n                                    </a>\r\n                                </li>\r\n                                <li className=\"list-inline-item icon\">\r\n                                    <a href=\"https://www.linkedin.com/in/muhammed-ekinci-622738194/\" rel=\"noreferrer\" target=\"_blank\">\r\n                                        <i class=\"fab fa-linkedin\"></i>\r\n                                    </a>\r\n                                </li>\r\n                                <li className=\"list-inline-item icon\">\r\n                                    <a href=\"https://www.facebook.com/siraceddin.ekinci\" rel=\"noreferrer\" target=\"_blank\">\r\n                                        <i class=\"fab fa-facebook\"></i>\r\n                                    </a>\r\n                                </li>\r\n                            </ul>\r\n                        </div>\r\n                    </Col>\r\n                    <Col sm={12} lg={8}>\r\n                        <h1 id=\"header-title\">Biography</h1>\r\n                        <p>My name is Muhammed Ekinci and I am currently a senior at William Paterson University majoring in Computer Science</p>\r\n                        <p>I am a young programmer, eager to always learn new concepts and ideas that will further my skills, especially about Programming. \r\n                            My dream is to become a Software Developer/Web Developer and I will do whatever it takes to accomplish that dream. \r\n                            I love to help people, and what I love to make are fun applications that people would enjoy just to make their day a little brighter.    \r\n                        </p>\r\n                        <Row>\r\n                            <Col md={7}>\r\n                                <h3>Education</h3>\r\n                                <ul className=\"ul-edu fa-ul\">\r\n                                    <li>\r\n                                        <i class=\"fas fa-graduation-cap\"></i>\r\n                                        <div className=\"descriptions\">\r\n                                            <p className=\"course\">Wayne Valley Highschool, 2017</p>\r\n                                        </div>\r\n                                    </li>\r\n                                    <li>\r\n                                        <i class=\"fas fa-graduation-cap\"></i>\r\n                                        <div className=\"descriptions\">\r\n                                            <p className=\"course\">Current CS Major in WPU, Expected to Graduate 2021</p>\r\n                                            <p className=\"institution\">William Paterson University</p>\r\n                                        </div>\r\n                                    </li>\r\n                                </ul>\r\n                            </Col>\r\n                        </Row>\r\n                    </Col>\r\n                </Row>\r\n            </Container>\r\n            <section id=\"skills-class\" className=\"home-section\">\r\n                <Container className=\"container\">\r\n                    <Row className=\"featurette\">\r\n                        <Col md={12} className=\"section-heading\">\r\n                            <h1>Skills</h1>\r\n                        </Col>\r\n                        <Col sm={4}>\r\n                            <div className=\"featurette-icon\">\r\n                                <i class=\"fab fa-js-square\"></i>\r\n                            </div>\r\n                            <h3>JavaScript</h3>\r\n                        </Col>\r\n                        <Col sm={4}>\r\n                            <div className=\"featurette-icon\">\r\n                                <i class=\"fab fa-react\"></i>                            \r\n                            </div>\r\n                            <h3>React</h3>\r\n                        </Col>\r\n                        <Col sm={4}>\r\n                            <div className=\"featurette-icon\">\r\n                                <i class=\"fab fa-html5\"></i>                            \r\n                            </div>\r\n                            <h3>HTML5</h3>\r\n                        </Col>\r\n                        <Col sm={4}>\r\n                            <div className=\"featurette-icon\">\r\n                                <i class=\"fab fa-css3-alt\"></i>                            \r\n                            </div>\r\n                            <h3>CSS3</h3>\r\n                        </Col>\r\n                        <Col sm={4}>\r\n                            <div className=\"featurette-icon\">\r\n                                <i class=\"fab fa-node-js\"></i>                            \r\n                            </div>\r\n                            <h3>Node.js</h3>\r\n                        </Col>\r\n                        <Col sm={4}>\r\n                            <div className=\"featurette-icon\">\r\n                                <i class=\"fas fa-database\"></i>                            \r\n                            </div>\r\n                            <h3>Databases</h3>\r\n                            <p>MySQL, MongoDB</p>\r\n                        </Col>\r\n                    </Row>\r\n                </Container>\r\n            </section>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default AboutMe;","C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\src\\components\\Navbar\\index.js",["55"],"import React from \"react\";\r\nimport \"./style.css\";\r\n\r\nexport function NavBar() {\r\n  return (\r\n    <nav className=\"navbar navbar-expand-sm navbar-dark bg-dark sticky-top\">\r\n        <a className=\"navbar-brand\" href=\"/\">Muhammed Ekinci</a>\r\n        <button className=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" aria-controls=\"navbarSupportedContent\" aria-expanded=\"false\" aria-label=\"Toggle 