\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\pages\\HomePage.js",[],"C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\components\\Navbar\\index.js",["50"],"C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\pages\\AboutMe.js",["51"],"C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\pages\\Portfolio.js",["52","53"],"import React from 'react';\r\nimport { Container, Row, Col, Image, Card, CardImg, CardDeck, Button } from \"react-bootstrap\";\r\nimport data from \"../components/Projects/projects\";\r\nimport \"../styles/Portfolio.css\";\r\n\r\nfunction Portfolio() {\r\n\r\n    return (\r\n        <Container fluid >\r\n            <Row>\r\n                <Col md={12} className=\"project-heading\">\r\n                    <h1 style={{textAlign: \"center\"}}>Projects</h1>\r\n                </Col>\r\n                <CardDeck>\r\n                    {data.map((project, i) => {\r\n                        return (\r\n                            <Col md={6}>\r\n                                <div key={i} className=\"cards\">\r\n                                    <Card>\r\n                                        <Card.Img className='cardImage' src={project.image} alt={project.alt}></Card.Img>\r\n                                        <div className=\"card-body\">\r\n                                            <Card.Body>\r\n                                                <Card.Title className=\"cardHeader\">{project.name}</Card.Title>\r\n                                                <Card.Text className=\"project-text\">{project.text}</Card.Text>\r\n                                                <Button className=\"app-btn\" variant=\"outline-primary\"  onClick={(e) => {e.preventDefault(); window.location.href=`${project.appUrl}`}}>Deploy The App</Button>\r\n                                                <Button className=\"github-btn\" variant=\"outline-primary\" onClick={(e) => {e.preventDefault(); window.location.href=`${project.githubUrl}`}}>Github Repository</Button>\r\n                                            </Card.Body>\r\n                                        </div>\r\n                                    </Card>\r\n                                </div>\r\n                            </Col>\r\n                        );\r\n                    })}\r\n                </CardDeck>\r\n            </Row>\r\n        </Container>\r\n    );\r\n};\r\n\r\nexport default Portfolio;","C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\components\\Projects\\projects.js",[],"C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\pages\\Contact.js",[],"C:\\Users\\Siraceddin\\Desktop\\HTML STUFF\\HW\\React-Portfolio\\react-porfolio\\src\\components\\Footer\\index.js",[],{"ruleId":"54","replacedBy":"55"},{"ruleId":"56","replacedBy":"57"},{"ruleId":"58","severity":1,"message":"59","line":23,"column":136,"nodeType":"60","endLine":23,"endColumn":151},{"ruleId":"58","severity":1,"message":"59","line":21,"column":70,"nodeType":"60","endLine":21,"endColumn":85},{"ruleId":"61","severity":1,"message":"62","line":2,"column":31,"nodeType":"63","messageId":"64","endLine":2,"endColumn":36},{"ruleId":"61","severity":1,"message":"65","line":2,"column":44,"nodeType":"63","messageId":"64","endLine":2,"endColumn":51},"no-native-reassign",["66"],"no-negated-in-lhs",["67"],"react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","JSXAttribute","no-unused-vars","'Image' is defined but never used.","Identifier","unusedVar","'CardImg' is defined but never used.","no-global-assign","no-unsafe-negation"]